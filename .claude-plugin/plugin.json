{
  "name": "cooldown",
  "description": "Cooldown reminders for Claude Code and other agent CLIs.",
  "author": {
    "name": "arsyadal",
    "url": "https://github.com/arsyadal"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/cooldown-session.cjs",
            "timeout": 5,
            "statusMessage": "Loading Cooldown status..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/cooldown-prompt.cjs",
            "timeout": 5,
            "statusMessage": "Refreshing Cooldown status..."
          }
        ]
      }
    ]
  }
}
